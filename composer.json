{
    "name": "eav93/wreq-php",
    "description": "PHP HTTP client with deterministic connection pooling and browser TLS/HTTP2 fingerprinting, built on the wreq Rust crate",
    "type": "library",
    "license": "LGPL-3.0-or-later",
    "keywords": ["http", "client", "tls", "fingerprint", "emulation", "keep-alive", "wreq"],
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Wreq\\": "src-php/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wreq\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": "Wreq\\Installer::run",
        "post-update-cmd": "Wreq\\Installer::run"
    },
    "extra": {
        "wreq": {
            "release-base": "https://github.com/wreq-php/wreq-php/releases/download"
        }
    },
    "config": {
        "sort-packages": true
    }
}
